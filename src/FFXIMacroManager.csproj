<?xml version="1.0" encoding="utf-8"?>
<Project ToolsVersion="Current" DefaultTargets="Build" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <Import Project="$(MSBuildExtensionsPath)\$(MSBuildToolsVersion)\Microsoft.Common.props" Condition="Exists('$(MSBuildExtensionsPath)\$(MSBuildToolsVersion)\Microsoft.Common.props')" />

  <PropertyGroup>
    <Configuration Condition=" '$(Configuration)' == '' ">Release</Configuration>
    <Platform Condition=" '$(Platform)' == '' ">AnyCPU</Platform>
    <ProjectGuid>{3F1A6C32-3F1A-4F1A-9F1A-1F1A1F1A1F1A}</ProjectGuid>
    <OutputType>WinExe</OutputType>
    <RootNamespace>FFXIMacroManager</RootNamespace>
    <AssemblyName>FFXIMacroManager</AssemblyName>
    <TargetFrameworkVersion>v4.7.2</TargetFrameworkVersion>
    <FileAlignment>512</FileAlignment>
    <ProjectTypeGuids>{60dc8134-eba5-43b8-bcc9-bb4bc16c2548};{FAE04EC0-301F-11D3-BF4B-00C04F79EFBC}</ProjectTypeGuids>
    <WarningLevel>4</WarningLevel>
    <Deterministic>true</Deterministic>
    <UseWPF>true</UseWPF>
    <AppDesignerFolder>Properties</AppDesignerFolder>
    <OutputPath>bin\$(Configuration)\</OutputPath>
    <IntermediateOutputPath>obj\$(Configuration)\</IntermediateOutputPath>
    <DebugType>portable</DebugType>
    <Optimize Condition=" '$(Configuration)' == 'Release' ">true</Optimize>
    <DebugSymbols Condition=" '$(Configuration)' == 'Debug' ">true</DebugSymbols>
  </PropertyGroup>

  <ItemGroup>
    <Reference Include="System" />
    <Reference Include="System.Core" />
    <Reference Include="System.Web" />
    <Reference Include="System.Web.Extensions" />
    <Reference Include="System.Xaml" />
    <Reference Include="System.Xml" />
    <Reference Include="System.Xml.Linq" />
    <Reference Include="System.Runtime.Serialization" />
    <Reference Include="System.Drawing" />
    <Reference Include="System.Windows.Forms" />
    <Reference Include="PresentationCore" />
    <Reference Include="PresentationFramework" />
    <Reference Include="WindowsBase" />
  </ItemGroup>

  <ItemGroup>
    <ApplicationDefinition Include="App.xaml">
      <Generator>MSBuild:Compile</Generator>
      <SubType>Designer</SubType>
    </ApplicationDefinition>
    <Page Include="MainWindow.xaml">
      <Generator>MSBuild:Compile</Generator>
      <SubType>Designer</SubType>
    </Page>
    <Page Include="Themes\GSUI.xaml">
      <Generator>MSBuild:Compile</Generator>
      <SubType>Designer</SubType>
    </Page>
  </ItemGroup>

  <ItemGroup>
    <Compile Include="App.xaml.cs">
      <DependentUpon>App.xaml</DependentUpon>
      <SubType>Code</SubType>
    </Compile>
    <Compile Include="MainWindow.xaml.cs">
      <DependentUpon>MainWindow.xaml</DependentUpon>
      <SubType>Code</SubType>
    </Compile>
    <Compile Include="Properties\AssemblyInfo.cs" />
    <Compile Include="Models\MacroFile.cs" />
    <Compile Include="Models\Character.cs" />
    <Compile Include="Models\BookTitles.cs" />
    <Compile Include="Data\SpellDb.cs" />
  </ItemGroup>

  <ItemGroup>
    <None Include="..\data\spells.json">
      <Link>data\spells.json</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <None Include="..\data\job_abilities.json">
      <Link>data\job_abilities.json</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <None Include="..\data\weapon_skills.json">
      <Link>data\weapon_skills.json</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <None Include="..\data\auto_translates.json">
      <Link>data\auto_translates.json</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <None Include="..\data\jobs.json">
      <Link>data\jobs.json</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>

  <Import Project="$(MSBuildToolsPath)\Microsoft.CSharp.targets" />
  <!-- WPF: pulls in MarkupCompilePass1/2 so XAML is compiled into BAML
       and matching .g.cs partial classes (with x:Name field declarations)
       are generated. Must come AFTER Microsoft.CSharp.targets.
       Searches the common locations: legacy .NET Framework MSBuild bin,
       Visual Studio install, and the dotnet-sdk WindowsDesktop targets. -->
  <Import Project="$(MSBuildBinPath)\Microsoft.WinFx.targets"
          Condition="Exists('$(MSBuildBinPath)\Microsoft.WinFx.targets')" />
  <Import Project="$(MSBuildToolsPath)\Microsoft.WinFx.targets"
          Condition="!Exists('$(MSBuildBinPath)\Microsoft.WinFx.targets') and Exists('$(MSBuildToolsPath)\Microsoft.WinFx.targets')" />
  <!-- dotnet-sdk path: WindowsDesktop SDK ships WinFX.targets in its
       targets folder. Hard-code the SDK base because legacy-style csproj
       doesn't know about Sdks/. The 8.0.421 version may shift over time
       so use a wildcard-resolving property if available. -->
  <PropertyGroup>
    <_WinFxFromSdk>$(MSBuildSDKsPath)\Microsoft.NET.Sdk.WindowsDesktop\targets\Microsoft.WinFX.targets</_WinFxFromSdk>
  </PropertyGroup>
  <Import Project="$(_WinFxFromSdk)"
          Condition="!Exists('$(MSBuildBinPath)\Microsoft.WinFx.targets')
                  and !Exists('$(MSBuildToolsPath)\Microsoft.WinFx.targets')
                  and Exists('$(_WinFxFromSdk)')" />
</Project>
